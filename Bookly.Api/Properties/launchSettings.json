{
  "profiles": {
    "http": {
      "commandName": "Project",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "dotnetRunMessages": true,
      "applicationUrl": "http://localhost:5219"
    },
    "https": {
      "commandName": "Project",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "dotnetRunMessages": true,
      "applicationUrl": "https://localhost:7080;http://localhost:5219"
    },
    "Container (Dockerfile)": {
      "commandName": "Docker",
      "launchBrowser": true, // 1. Forces the browser to open
      "launchUrl": "{Scheme}://localhost:8001/scalar/v1", // 2. Hardcodes host port 8001
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_HTTPS_PORTS": "8081",
        "ASPNETCORE_HTTP_PORTS": "8080"
      },
      "httpPort": 8000, // 3. Binds local HTTP to port 8000
      "sslPort": 8001, // 4. Binds local HTTPS to port 8001
      "useSSL": true
    }
  },
  "$schema": "https://json.schemastore.org/launchsettings.json"
}